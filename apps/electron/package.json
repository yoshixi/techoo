{
  "name": "electron",
  "version": "0.0.4",
  "type": "module",
  "private": true,
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "check-types:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "check-types:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "check-types": "npm run check-types:node && npm run check-types:web",
    "start": "electron-vite preview",
    "start:direct": "mv out/main/index.js out/main/index.cjs && ./node_modules/.bin/electron .",
    "start:api": "cp .env.api .env && electron-vite preview",
    "dev": "electron-vite dev",
    "dev:api": "cp .env.api .env && electron-vite dev",
    "dev:prod": "cp .env.prod .env && electron-vite dev",
    "dev:build": "electron-vite build && npm run start:direct",
    "build": "npm run check-types && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "orval:generate": "orval --config ./orval.config.js",
    "orval:watch": "orval --config ./orval.config.js --watch",
    "gen:openapi": "pnpm --filter @scripts/openapischema-generator generate --path apps/electron",
    "api:generate": "pnpm run gen:openapi && pnpm run orval:generate",
    "test": "echo 'No tests for electron yet'"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.17",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "swr": "^2.3.8",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.18.10",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.0.3",
    "electron": "^38.1.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "orval": "^7.17.0",
    "prettier": "^3.6.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.6"
  }
}
