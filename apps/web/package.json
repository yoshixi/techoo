{
  "name": "@apps/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "dev:local": "unset TURSO_CONNECTION_URL TURSO_AUTH_TOKEN && next dev --turbopack --port 3000",
    "dev:prod": "next dev --turbopack --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "drizzle:push:local": "drizzle-kit push --config ./drizzle.config.local.ts",
    "drizzle:pull:local": "drizzle-kit pull --config ./drizzle.config.local.ts",
    "drizzle:studio:local": "drizzle-kit studio --config ./drizzle.config.local.ts",
    "drizzle:generate:prod": "drizzle-kit generate --config ./drizzle.config.prod.ts",
    "drizzle:migrate:prod": "drizzle-kit migrate --config ./drizzle.config.prod.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": "./app/api/[[...route]]/route.ts"
  },
  "types": "./app/api/[[...route]]/route.ts",
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@libsql/client": "^0.15.15",
    "@repo/ui": "workspace:*",
    "better-auth": "^1.4.18",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "googleapis": "^170.1.0",
    "hono": "^4.10.6",
    "jose": "^6.1.3",
    "next": "16.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.31.7",
    "drizzle-seed": "^0.3.1",
    "eslint": "^9.34.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.13"
  }
}
