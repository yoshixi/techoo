{
  "name": "@apps/backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config ./wrangler.jsonc",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "deploy:prod": "CLOUDFLARE_ENV=prod $npm_execpath run build && CLOUDFLARE_ENV=prod wrangler deploy --env prod",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "drizzle:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "drizzle:generate:prod": "DOTENV_CONFIG_PATH=.env.prod drizzle-kit generate --config ./drizzle.config.ts",
    "drizzle:migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
    "drizzle:migrate:prod": "DOTENV_CONFIG_PATH=.env.prod drizzle-kit migrate --config ./drizzle.config.ts",
    "drizzle:push": "drizzle-kit push --config ./drizzle.config.ts",
    "drizzle:push:prod": "DOTENV_CONFIG_PATH=.env.prod drizzle-kit push --config ./drizzle.config.ts",
    "drizzle:push:seed": "DOTENV_CONFIG_PATH=.env.prod drizzle-kit push --config ./drizzle.config.seed.ts",
    "migrate:tenants": "DOTENV_CONFIG_PATH=.env.prod npx tsx scripts/migrate-tenants.ts",
    "migrate:all": "DOTENV_CONFIG_PATH=.env npx tsx scripts/migrate-all.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "npx tsx scripts/e2e.ts"
  },
  "exports": {
    ".": "./src/app/api/[[...route]]/route.ts"
  },
  "types": "./src/app/api/[[...route]]/route.ts",
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@libsql/client": "^0.15.15",
    "better-auth": "^1.4.18",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.6",
    "jose": "^6.1.3",
    "tenanso": "^0.2.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "@hono/node-server": "^1.19.11",
    "@types/node": "^22.15.3",
    "drizzle-kit": "^0.31.7",
    "miniflare": "4.20260212.0",
    "tsx": "^4.19.4",
    "typescript": "5.9.3",
    "vite": "^6.3.5",
    "vite-ssr-components": "^0.5.2",
    "vitest": "^4.0.13",
    "wrangler": "^4.17.0"
  }
}
