# Local Development Environment
# Turso is required for wrangler dev / workers runtime.
# Local SQLite is used for Node-only runs.

NODE_ENV=development

# Authentication (required)
BETTER_AUTH_SECRET=your-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:8787
JWT_SECRET=your-jwt-secret-at-least-32-chars
# Comma-separated origins allowed for auth requests (Electron dev server, etc.)
TRUSTED_ORIGINS=http://localhost:5173
MOBILE_REDIRECT_URIS=exp+techoo://auth-callback,exp+techoo://link-callback,techoo://auth-callback,techoo://link-callback

# Local SQLite (Node runtime only)
SQLITE_URL="file:./tmp/local.db"

# Turso — centralized DB (required for wrangler dev / workers runtime)
TURSO_MAIN_DB_URL=""
TURSO_MAIN_DB_AUTH_TOKEN=""

# Tenanso — per-user tenant databases (optional for local dev)
# When not set, all data goes to the single local SQLite DB.
# TURSO_ORG_SLUG=your-org-slug
# TURSO_API_TOKEN=your-turso-api-token
# TURSO_GROUP=default
# TURSO_GROUP_AUTH_TOKEN=your-group-auth-token
# TURSO_TENANT_DB_URL=libsql://{tenant}-your-org.turso.io
# TURSO_SEED_DB_URL=libsql://your-seed-db-your-org.turso.io

# OAuth Providers (optional for local dev)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# APPLE_CLIENT_ID=your-apple-client-id
# APPLE_CLIENT_SECRET=your-apple-client-secret

# For GOOGLE CALENDAR SYNC
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
