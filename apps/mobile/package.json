{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "DEBUG=true expo start -c",
    "android": "DEBUG=true expo start -c --android",
    "ios": "DEBUG=true expo start -c --ios",
    "web": "DEBUG=true expo start -c --web",
    "clean": "rm -rf .expo node_modules",
    "gen:openapi": "cp ../electron/openapi.json ./openapi.json || cp ../web/openapi.json ./openapi.json || true",
    "orval:generate": "orval --config ./orval.config.js",
    "api:generate": "pnpm run gen:openapi && pnpm run orval:generate",
    "test": "jest",
    "test:watch": "jest --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "build": "eas build -p all",
    "build:android": "eas build -p android",
    "build:ios": "eas build -p ios",
    "build:dev": "eas build -p all --profile development",
    "build:preview": "eas build -p all --profile preview"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-navigation/native": "^7.0.0",
    "@rn-primitives/portal": "~1.3.0",
    "@rn-primitives/slot": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~54.0.34",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.12",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.19",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "^15.0.11",
    "lucide-react-native": "^0.545.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "eas-cli": "^18.0.3",
    "jest-expo": "^54.0.16",
    "orval": "^7.17.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "5.9.3"
  },
  "private": true
}
