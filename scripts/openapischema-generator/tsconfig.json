{
    "compilerOptions": {
      "baseUrl": ".",
      "module": "ESNext",
      "moduleResolution": "node",
      "target": "ES2022",
      "strict": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "paths": {
        "@apps/web": ["../../apps/web/app/api/[[...route]]/route.ts"]
      }
    }
  }