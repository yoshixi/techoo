{
    "compilerOptions": {
      "baseUrl": ".",
      "module": "ESNext",
      "moduleResolution": "node",
      "target": "ES2022",
      "strict": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "paths": {
      "@apps/backend": ["../../apps/backend/src/app/api/[[...route]]/route.ts"]
      }
    }
  }
