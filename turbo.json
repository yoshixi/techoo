{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "test": {
      "dependsOn": [
        "^test"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate": {
      "cache": false,
      "env": [
        "TURSO_CONNECTION_URL",
        "TURSO_AUTH_TOKEN"
      ],
      "inputs": [
        "../../apps/web/app/api/**"
      ]
    }
  },
  "globalEnv": [
    "NODE_ENV",
    "TURSO_CONNECTION_URL",
    "TURSO_AUTH_TOKEN",
    "TURSO_DATABASE_URL"
  ]
}
